{
  "name": "altai-scroll-story",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate-content && npm run typecheck && vite build",
    "preview": "vite preview",
    "route": "node --import tsx scripts/build-route.ts",
    "photos": "node --import tsx scripts/process-photos.ts",
    "validate-content": "node --import tsx scripts/validate-content.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@yandex/ymaps3-types": "^1.0.20315584",
    "exifr": "^7.1.3",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
